    "settings.mode.highWarning.message" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In High Security mode, if Face ID / Touch ID becomes unavailable, you will be unable to access your private keys. Ensure you have a current backup. Biometric authentication is required to confirm this change."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在高安全模式下，如果 Face ID / Touch ID 不可用，你将无法访问你的私钥。请确保你有最新的备份。需要生物认证来确认此更改。"
          }
        }
      }
    },
    "settings.mode.highWarning.message.mac" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In High Security mode, if Touch ID becomes unavailable, you will be unable to access your private keys. Ensure you have a current backup. Biometric authentication is required to confirm this change."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在高安全模式下，如果 Touch ID 不可用，你将无法访问你的私钥。请确保你有最新的备份。需要生物认证来确认此更改。"
          }
        }
      }
    },
    "settings.mode.highWarning.noBackup" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WARNING: In High Security mode, if Face ID / Touch ID becomes unavailable, you will be unable to access your private keys. You have NOT backed up any keys. If biometrics fail, your keys will be permanently inaccessible. Back up your keys first, or proceed at your own risk."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "警告：在高安全模式下，如果 Face ID / Touch ID 不可用，你将无法访问你的私钥。你尚未备份任何密钥。如果生物认证失败，你的密钥将永久无法访问。请先备份密钥，或自行承担风险继续。"
          }
        }
      }
    },
    "settings.mode.highWarning.noBackup.mac" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WARNING: In High Security mode, if Touch ID becomes unavailable, you will be unable to access your private keys. You have NOT backed up any keys. If biometrics fail, your keys will be permanently inaccessible. Back up your keys first, or proceed at your own risk."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "警告：在高安全模式下，如果 Touch ID 不可用，你将无法访问你的私钥。你尚未备份任何密钥。如果生物认证失败，你的密钥将永久无法访问。请先备份密钥，或自行承担风险继续。"
