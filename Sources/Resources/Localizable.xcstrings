    "onboarding.p2.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compatible with GnuPG and other PGP tools. Your contacts can verify your messages with any standards-compliant software."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "兼容 GnuPG 和其他 PGP 工具。你的联系人可以使用任何符合标准的软件验证你的消息。"
          }
        }
      }
    },
