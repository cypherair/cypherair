    "onboarding.p1.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CypherAir never connects to the internet. Your messages and keys stay on your device."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CypherAir 永不联网。你的消息和密钥始终留在你的设备上。"
          }
        }
      }
    },
    "onboarding.p1.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completely Offline"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "完全离线"
          }
        }
      }
    },
    "onboarding.p2.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compatible with GnuPG and other PGP tools. Your contacts can verify your messages with any standards-compliant software."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "兼容 GnuPG 和其他 PGP 工具。你的联系人可以使用任何符合标准的软件验证你的消息。"
          }
        }
      }
    },
    "onboarding.p2.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenPGP Standard"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenPGP 标准"
          }
        }
      }
    },
    "onboarding.p3.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Learn CypherAir in an isolated sandbox first, or skip the tutorial and enter the real app right away. Tutorial actions never touch your real keys, contacts, settings, files, exports, or private-key security assets."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你可以先在隔离的教程沙箱中了解 CypherAir，或直接跳过教程进入真实应用。教程中的操作不会触碰你的真实密钥、联系人、设置、文件、导出内容或私钥安全资产。"
          }
        }
      }
    },
    "onboarding.p3.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start with a Guided Tutorial"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "先通过引导教程快速上手"
          }
        }
      }
    },
