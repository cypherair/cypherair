    "onboarding.p1.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CypherAir never connects to the internet. Your messages and keys stay on your device."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CypherAir 永不联网。你的消息和密钥始终留在你的设备上。"
          }
        }
      }
    },
    "onboarding.p1.title" : {
      "localizations" : {
