    "guidedTutorial.sandbox.confirm.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Guided Tutorial runs in a separate sandbox. The keys, contacts, settings, messages, exports, and temporary data created here never affect your real workspace, and the sandbox data is cleaned up when you reset or finish the tutorial."
