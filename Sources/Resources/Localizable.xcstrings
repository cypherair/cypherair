    "onboarding.p3.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Learn CypherAir in an isolated sandbox first, or skip the tutorial and enter the real app right away. Tutorial actions never touch your real keys, contacts, settings, files, exports, or private-key security assets."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你可以先在隔离的教程沙箱中了解 CypherAir，或直接跳过教程进入真实应用。教程中的操作不会触碰你的真实密钥、联系人、设置、文件、导出内容或私钥安全资产。"
          }
        }
      }
    },
